# ===== DeepSeek AI Model =====
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ===== Finnhub API - 股票实时报价 =====
# Free: 1000 calls/month (约 33 次/天)
# 获取地址: https://finnhub.io (需要注册)
# 用于: get_current_quote() - 获取实时股价、涨跌、开高低等
FINNHUB_API_KEY=your_finnhub_api_key_here

# ===== Alpha Vantage API - 公司信息 =====
# Free: 5 calls/minute (够用)
# 获取地址: https://www.alphavantage.co/api (需要注册)
# 用于: get_company_profile() - 获取公司情绪分析
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# ===== NewsAPI - 新闻数据 =====
# Free: 100 requests/day (足够)
# 获取地址: https://newsapi.org (需要注册)
# 用于: get_recent_news() - 获取最新新闻和情绪分析
NEWSAPI_API_KEY=your_newsapi_api_key_here

# ===== LangSmith 评估 (可选) =====
# 仅用于 eval_agent.py 的评估和追踪
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=stock-agent-evaluation
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ===== 应用设置 =====
APP_TEMPERATURE=0.1
EVAL_TEMPERATURE=0.0
